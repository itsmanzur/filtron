{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "filtron/select",
	"title": "Filtron select",
	"category": "filtron",
	"icon": "menu",
	"description": "Select dropdown filter (taxonomy or meta facets).",
	"keywords": [ "filtron", "filter", "select", "dropdown" ],
	"textdomain": "filtron",
	"usesContext": [ "postType" ],
	"attributes": {
		"label": {
			"type": "string",
			"default": ""
		},
		"sourceType": {
			"type": "string",
			"default": "taxonomy"
		},
		"sourceKey": {
			"type": "string",
			"default": ""
		},
		"showCount": {
			"type": "boolean",
			"default": true
		},
		"placeholder": {
			"type": "string",
			"default": "Any"
		},
		"logic": {
			"type": "string",
			"default": "OR"
		}
	},
	"supports": {
		"html": false
	},
	"editorScript": "filtron-blocks-editor"
}
